# --- Credentials / secrets ---
**/auth.json
.env
.env.*
!.env.example

# --- Dependencies / generated bins ---
node_modules/
agent/node_modules/
agent/npm/node_modules/
npm/
!agent/npm/
!agent/npm/package.json
!agent/npm/package-lock.json
bin/

# --- Pi runtime / local OS state ---
# OS-specific and runtime files are created/updated locally by Pi/extensions.
# Do not track them: Windows/Linux/macOS would otherwise keep flipping them.
agent/heimdall.json
agent/run-history.jsonl
agent/intercom/
sessions/

# Keep Hermes memory databases/user memories private, but publish reusable skills.
agent/pi-hermes-memory/*
!agent/pi-hermes-memory/skills/
!agent/pi-hermes-memory/skills/**/
!agent/pi-hermes-memory/skills/**/SKILL.md

# Keep project memories private, but publish project-scoped skills.
agent/projects-memory/*
!agent/projects-memory/*/
agent/projects-memory/*/*
!agent/projects-memory/*/skills/
!agent/projects-memory/*/skills/**/
!agent/projects-memory/*/skills/**/SKILL.md

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Editor / OS ---
.DS_Store
Thumbs.db
.vscode/*
!.vscode/settings.json
.idea/
*.swp